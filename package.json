{
  "name": "mining-drones-idle",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev:wasm:watch": "cd rust-engine && cargo watch -s \"wasm-pack build --target web --out-dir ../src/gen --features wasm\"",
    "check:wasm-pack": "node ./scripts/check-wasm-pack.js",
    "dev": "concurrently \"pnpm run dev:wasm:watch\" \"vite\"",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "build:wasm": "cd rust-engine && wasm-pack build --no-opt --target web --out-dir ../src/gen --features wasm",
    "prebuild:wasm": "node ./scripts/check-wasm-pack.js",
    "build": "pnpm run build:wasm && tsc -b && vite build",
    "build:output": "pnpm run build",
    "deploy:pages": "echo 'Use GitHub Actions to deploy on tag push'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "e2e": "playwright test",
    "scan-long-files": "node scripts/scan-long-files.cjs"
  },
  "dependencies": {
    "@radix-ui/themes": "^3.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/three": "^0.183.1",
    "ajv": "^8.18.0",
    "immer": "^11.1.4",
    "miniplex": "^2.0.0",
    "miniplex-react": "^2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "tslib": "^2.8.1",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/config-array": "0.19.2",
    "@eslint/core": "0.12.0",
    "@eslint/eslintrc": "3.3.0",
    "@eslint/js": "9.21.0",
    "@eslint/object-schema": "2.1.6",
    "@eslint/plugin-kit": "0.2.7",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@typescript-eslint/scope-manager": "8.57.1",
    "@typescript-eslint/type-utils": "^8.57.1",
    "@typescript-eslint/types": "8.57.1",
    "@typescript-eslint/typescript-estree": "8.57.1",
    "@typescript-eslint/utils": "8.57.1",
    "@typescript-eslint/visitor-keys": "8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "coverage-v8": "0.0.1-security",
    "esbuild": "^0.27.4",
    "eslint": "9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "less": "^4.6.4",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup": "^4.59.0",
    "sass-embedded": "^1.98.0",
    "stylus": "^0.64.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
